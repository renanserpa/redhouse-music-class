rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/teachers/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == 'serparenan@gmail.com');
    }

    // Schools: Read by authenticated users, write by admins
    match /schools/{schoolId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Teachers: Read by authenticated users, write by admins or self (limited)
    match /teachers/{teacherId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOwner(teacherId);
    }

    // Classrooms: Read by authenticated users, write by admins or assigned teacher
    match /classrooms/{classroomId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.teacherId);
    }

    // Students: Read by authenticated users, write by admins or teacher of the classroom
    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isAuthenticated();
    }

    // Lessons: Read by authenticated users, write by teacher who created it or admin
    match /lessons/{lessonId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.createdByTeacherId);
    }

    // Monthly Reports: Read by authenticated users, write by teacher or admin
    match /monthlyReports/{reportId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Activity Attempts: Read by authenticated users, write by teacher
    match /activityAttempts/{attemptId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    // Activities: Read by authenticated users, write by admins
    match /activities/{activityId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
